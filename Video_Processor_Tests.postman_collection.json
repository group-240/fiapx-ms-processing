	"item": [
		{
			"name": "Upload Vídeo",
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "formdata",
					"formdata": [
						{
							"key": "id",
							"type": "text",
							"value": "123"
						},
						{
							"key": "email",
							"type": "text",
							"value": "usuario@dominio.com"
						},
						{
							"key": "file",
							"type": "file",
							"src": [],
							"description": "Selecione um arquivo de vídeo"
						}
					]
				},
				"url": {
					"raw": "{{base_url}}/api/capturas/upload",
					"host": ["{{base_url}}"],
					"path": ["api", "capturas", "upload"]
				},
				"description": "Envia um vídeo para processamento assíncrono com id (integer) e email."
			},
			"response": []
		},
		{
			"name": "Atualizar Status de Captura",
			"request": {
				"method": "PUT",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"id\": 123,\n  \"status\": \"PROCESSANDO\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/api/capturas/update-status",
					"host": ["{{base_url}}"],
					"path": ["api", "capturas", "update-status"]
				},
				"description": "Atualiza o status da captura para CONCLUIDO, PROCESSANDO ou ERRO."
			},
			"response": []
		},
		{
			"name": "Download Capturas (ZIP)",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "Accept",
						"value": "application/zip"
					}
				],
				"url": {
					"raw": "{{base_url}}/api/capturas/download/3214",
					"host": ["{{base_url}}"],
					"path": ["api", "capturas", "download", "3214"]
				},
				"description": "Realiza o download do arquivo ZIP contendo as capturas geradas para o id informado."
			},
			"response": []
		},
